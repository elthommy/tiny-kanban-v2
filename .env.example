# Tiny-kanban configuration — copy to .env and adjust.
# All values are optional; the defaults below are what you get without a .env.

# Port the FastAPI backend listens on (serves the UI + /api)
KANBAN_BACKEND_PORT=8000

# Host interface the backend binds to (0.0.0.0 to expose on the network)
KANBAN_HOST=127.0.0.1

# Port of the Vite dev server (development only, ./start.sh dev)
KANBAN_FRONTEND_PORT=5173

# Where the SQLite database file lives
# KANBAN_DB_PATH=/absolute/path/to/board.db
